<Ui xmlns="http://www.blizzard.com/wow/ui/" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://www.blizzard.com/wow/ui/
..\..\FrameXML\UI.xsd">
	<Script file="Custom_ClassNameplateBar_RogueDruid.lua"/>

	<Frame name="ClassNameplateBarComboPointFrame" virtual="true">
		<Size x="13" y="13"/>
		<Layers>
			<Layer level="BACKGROUND">
				<Texture parentKey="Background"/>
			</Layer>
			<Layer level="ARTWORK">
				<Texture parentKey="Point"/>
			</Layer>
		</Layers>
		<Scripts>
			<OnLoad>
				local parent = self:GetParent()
				if not parent.ComboPoints then
					parent.ComboPoints = {}
				end
				table.insert(parent.ComboPoints, self)

				self.Background:SetAtlas("ClassOverlay-ComboPoint-Off")
				self.Point:SetAtlas("ClassOverlay-ComboPoint")
			</OnLoad>
		</Scripts>
	</Frame>

	<Frame name="ClassNameplateBarRogueDruidFrame" inherits="ClassNameplateBarFrame">
		<Size x="80" y="13"/>
		<Frames>
			<Frame name="$parentCombo1" parentKey="Combo1" inherits="ClassNameplateBarComboPointFrame">
				<Anchors>
					<Anchor point="TOPLEFT" x="0" y="0"/>
				</Anchors>
			</Frame>
			<Frame name="$parentCombo2" parentKey="Combo2" inherits="ClassNameplateBarComboPointFrame">
				<Anchors>
					<Anchor point="LEFT" relativeTo="$parentCombo1" relativePoint="RIGHT" x="4" y="0"/>
				</Anchors>
			</Frame>
			<Frame name="$parentCombo3" parentKey="Combo3" inherits="ClassNameplateBarComboPointFrame">
				<Anchors>
					<Anchor point="LEFT" relativeTo="$parentCombo2" relativePoint="RIGHT" x="4" y="0"/>
				</Anchors>
			</Frame>
			<Frame name="$parentCombo4" parentKey="Combo4" inherits="ClassNameplateBarComboPointFrame">
				<Anchors>
					<Anchor point="LEFT" relativeTo="$parentCombo3" relativePoint="RIGHT" x="4" y="0"/>
				</Anchors>
			</Frame>
			<Frame name="$parentCombo5" parentKey="Combo5" inherits="ClassNameplateBarComboPointFrame">
				<Anchors>
					<Anchor point="LEFT" relativeTo="$parentCombo4" relativePoint="RIGHT" x="4" y="0"/>
				</Anchors>
			</Frame>
		</Frames>
		<Scripts>
			<OnLoad>
				Mixin(self, ClassNameplateBar, ClassNameplateBarRogueDruid)
				self:OnLoad()
			</OnLoad>
			<OnEvent>
				self:OnEvent(event, ...)
			</OnEvent>
		</Scripts>
	</Frame>
</Ui>
