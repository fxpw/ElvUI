<Ui xmlns="http://www.blizzard.com/wow/ui/" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://www.blizzard.com/wow/ui/
..\..\FrameXML\UI.xsd">
	<Script file="Custom_NamePlates.lua"/>

	<Frame name="NamePlateDriverFrame" toplevel="true">
		<Scripts>
			<OnLoad>
				Mixin(self, NamePlateDriverMixin)
				self:OnLoad()
			</OnLoad>
			<OnEvent>
				self:OnEvent(event, ...)
			</OnEvent>
		</Scripts>
	</Frame>

	<Frame name="NameplateBuffButtonTemplate" virtual="true" enableMouse="true" hidden="true">
		<Size x="20" y="14"/>
		<Layers>
			<Layer level="BACKGROUND">
				<Texture parentKey="Border" setAllPoints="true">
					<Color r="0" g="0" b="0"/>
				</Texture>
			</Layer>
			<Layer level="ARTWORK">
				<Texture parentKey="Icon">
					<Size x="18" y="12"/>
					<Anchors>
						<Anchor point="CENTER"/>
					</Anchors>
					<TexCoords left="0.05" right="0.95" top="0.1" bottom="0.6"/>
				</Texture>
			</Layer>
		</Layers>
		<Frames>
			<Cooldown parentKey="Cooldown" inherits="CooldownFrameTemplate" reverse="true" drawEdge="true" hidden="true">
				<Anchors>
					<Anchor point="CENTER" x="0" y="-1"/>
				</Anchors>
			</Cooldown>
			<Frame parentKey="CountFrame" setAllPoints="true">
				<Layers>
					<Layer level="ARTWORK">
						<FontString parentKey="Count" inherits="NumberFontNormalSmall" justifyH="RIGHT">
							<Anchors>
								<Anchor point="BOTTOMRIGHT" x="3" y="-2"/>
							</Anchors>
						</FontString>
					</Layer>
				</Layers>
			</Frame>
		</Frames>
		<Scripts>
			<OnLoad>
				Mixin(self, NameplateBuffButtonTemplateMixin)
			</OnLoad>
			<OnEnter>
				self:OnEnter()
			</OnEnter>
			<OnLeave>
				self:OnLeave()
			</OnLeave>
		</Scripts>
	</Frame>

	<Frame name="NamePlateFullBorderTemplate" setAllPoints="true" virtual="true">
		<Layers>
			<Layer level="BORDER">
				<!-- Left -->
				<Texture parentKey="Left">
					<Size x="1" y="0"/>
					<Anchors>
						<Anchor point="TOPRIGHT" relativePoint="TOPLEFT" x="0" y="1"/>
						<Anchor point="BOTTOMRIGHT" relativePoint="BOTTOMLEFT" x="0" y="-1"/>
					</Anchors>
					<Color r="1" g="1" b="1" a="1"/>
				</Texture>

				<!-- Right -->
				<Texture parentKey="Right">
					<Size x="1" y="0"/>
					<Anchors>
						<Anchor point="TOPLEFT" relativePoint="TOPRIGHT" x="0" y="1"/>
						<Anchor point="BOTTOMLEFT" relativePoint="BOTTOMRIGHT" x="0" y="-1"/>
					</Anchors>
					<Color r="1" g="1" b="1" a="1"/>
				</Texture>

				<!-- Bottom -->
				<Texture parentKey="Bottom">
					<Size x="0" y="1"/>
					<Anchors>
						<Anchor point="TOPLEFT" relativePoint="BOTTOMLEFT"/>
						<Anchor point="TOPRIGHT" relativePoint="BOTTOMRIGHT"/>
					</Anchors>
					<Color r="1" g="1" b="1" a="1"/>
				</Texture>

				<!-- Top -->
				<Texture parentKey="Top">
					<Size x="0" y="1"/>
					<Anchors>
						<Anchor point="BOTTOMLEFT" relativePoint="TOPLEFT"/>
                        <Anchor point="BOTTOMRIGHT" relativePoint="TOPRIGHT"/>
					</Anchors>
					<Color r="1" g="1" b="1" a="1"/>
				</Texture>
			</Layer>
		</Layers>
		<Scripts>
			<OnLoad>
				Mixin(self, NamePlateBorderTemplateMixin)
				self:OnLoad()
			</OnLoad>
		</Scripts>
	</Frame>

	<Frame name="NamePlateSecondaryBarBorderTemplate" setAllPoints="true" virtual="true">
		<Layers>
			<Layer level="BORDER">
				<!-- Left -->
				<Texture parentKey="Left">
					<Size x="1" y="0"/>
					<Anchors>
						<Anchor point="TOPRIGHT" relativePoint="TOPLEFT" x="0" y="1"/>
						<Anchor point="BOTTOMRIGHT" relativePoint="BOTTOMLEFT" x="0" y="-1"/>
					</Anchors>
					<Color r="1" g="1" b="1" a="1"/>
				</Texture>

				<!-- Right -->
				<Texture parentKey="Right">
					<Size x="1" y="0"/>
					<Anchors>
						<Anchor point="TOPLEFT" relativePoint="TOPRIGHT" x="0" y="1"/>
						<Anchor point="BOTTOMLEFT" relativePoint="BOTTOMRIGHT" x="0" y="-1"/>
					</Anchors>
					<Color r="1" g="1" b="1" a="1"/>
				</Texture>

				<!-- Bottom -->
				<Texture parentKey="Bottom">
					<Size x="0" y="1"/>
					<Anchors>
                        <Anchor point="TOPLEFT" relativePoint="BOTTOMLEFT"/>
                        <Anchor point="TOPRIGHT" relativePoint="BOTTOMRIGHT"/>
					</Anchors>
					<Color r="1" g="1" b="1" a="1"/>
				</Texture>
			</Layer>
		</Layers>
		<Scripts>
			<OnLoad>
				Mixin(self, NamePlateBorderTemplateMixin)
				self:OnLoad()
			</OnLoad>
		</Scripts>
	</Frame>

	<Button name="BaseNamePlateUnitFrameTemplate" parentKey="UnitFrame" virtual="true">
		<Anchors>
			<Anchor point="CENTER"/>
		</Anchors>
		<Frames>
			<StatusBar name="$parentHealthBar" parentKey="healthBar">
				<Frames>
					<Frame name="$parentBorder" parentKey="border" inherits="NamePlateFullBorderTemplate"/>
					<Frame name="$parentOverlay" parentKey="overlay" setAllPoints="true">
						<Layers>
							<Layer level="BACKGROUND">
								<Texture name="$parentMyHealPrediction" parentKey="myHealPrediction"/>
								<Texture name="$parentOtherHealPrediction" parentKey="otherHealPrediction"/>
								<Texture name="$parentTotalAbsorb" parentKey="totalAbsorb"/>
							</Layer>
							<Layer level="BORDER">
								<Texture name="$parentTotalAbsorbOverlay" parentKey="totalAbsorbOverlay"/>
							</Layer>
							<Layer level="ARTWORK">
								<Texture name="$parentMyHealAbsorb" parentKey="myHealAbsorb"/>
								<Texture name="$parentMyHealAbsorbLeftShadow" parentKey="myHealAbsorbLeftShadow" file="Interface\RaidFrame\Absorb-Edge"/>
								<Texture name="$parentMyHealAbsorbRightShadow" parentKey="myHealAbsorbRightShadow" file="Interface\RaidFrame\Absorb-Edge">
									<TexCoords left="1" right="0" top="0" bottom="1"/>
								</Texture>
							</Layer>
							<Layer level="OVERLAY">
								<Texture name="$parentOverAbsorbGlow" parentKey="overAbsorbGlow"/>
								<Texture name="$parentOverHealAbsorbGlow" parentKey="overHealAbsorbGlow"/>
							</Layer>
						</Layers>
					</Frame>
				</Frames>
				<Layers>
					<Layer level="BACKGROUND">
						<Texture name="$parentBackground" parentKey="background">
							<Color r="0.2" g="0.2" b="0.2" a="0.85"/>
						</Texture>
					</Layer>
				</Layers>
				<BarTexture name="$parentBarTexture" parentKey="barTexture" file="Interface/TargetingFrame/UI-TargetingFrame-BarFill"/>
			</StatusBar>

			<StatusBar name="$parentCastBar" parentKey="castBar" hidden="true">
				<Layers>
					<Layer level="BACKGROUND">
						<Texture name="$parentBackground" parentKey="background">
							<Color r="0.2" g="0.2" b="0.2" a="0.85"/>
						</Texture>
					</Layer>
					<Layer level="OVERLAY">
						<Texture name="$parentIcon" parentKey="Icon" hidden="true">
							<Size x="10" y="10"/>
							<Anchors>
								<Anchor point="LEFT" x="0" y="0"/>
							</Anchors>
						</Texture>
						<FontString name="$parentText" parentKey="Text" inherits="SystemFont_Shadow_Small">
							<Size x="0" y="16"/>
							<Anchors>
								<Anchor point="LEFT" relativeKey="$parentIcon" relativePoint="RIGHT" x="0" y="0"/>
								<Anchor point="RIGHT" relativePoint="RIGHT" x="0" y="0"/>
							</Anchors>
						</FontString>
						<Texture name="$parentBorderShield" parentKey="BorderShield" hidden="true">
							<Size x="10" y="12"/>
							<Anchors>
								<Anchor point="CENTER" x="-2" y="-1"/>
							</Anchors>
						</Texture>

						<Texture name="$parentSpark" parentKey="Spark" file="Interface\CastingBar\UI-CastingBar-Spark" alphaMode="ADD">
							<Size x="16" y="16"/>
							<Anchors>
								<Anchor point="CENTER" x="0" y="0"/>
							</Anchors>
						</Texture>
						<Texture name="$parentFlash" parentKey="Flash" file="Interface\TargetingFrame\UI-TargetingFrame-BarFill" alphaMode="ADD"/>
					</Layer>
				</Layers>
				<Scripts>
					<OnLoad>
						self.BorderShield:SetAtlas("nameplates-InterruptShield")

						self.iconWhenNoninterruptible = true

						CastingBarFrame_OnLoad(self, nil, false, true);
					</OnLoad>
					<OnEvent function="CastingBarFrame_OnEvent"/>
					<OnUpdate function="CastingBarFrame_OnUpdate"/>
					<OnShow function="CastingBarFrame_OnShow"/>
				</Scripts>
				<BarTexture file="Interface\TargetingFrame\UI-StatusBar"/>
				<BarColor r="1.0" g="0.7" b="0.0"/>
			</StatusBar>

			<Frame name="$parentBuffFrame" parentKey="BuffFrame" inherits="HorizontalLayoutFrame">
				<Anchors>
					<Anchor point="LEFT" relativeTo="$parentHealthBar" x="-1"/>
				</Anchors>
				<Scripts>
					<OnLoad>
						self.spacing = 4
						self.fixedHeight = 14

						Mixin(self, LayoutMixin, HorizontalLayoutMixin, NameplateBuffContainerMixin)
						self:OnLoad()
					</OnLoad>
					<OnEvent>
						self:OnEvent(event, ...)
					</OnEvent>
				</Scripts>
			</Frame>
			<Frame name="$parentRaidTargetFrame" parentKey="RaidTargetFrame">
				<Size x="22" y="22"/>
				<Anchors>
					<Anchor point="RIGHT" relativeTo="$parentHealthBar" relativePoint="LEFT" x="-15"/>
				</Anchors>
				<Layers>
					<Layer level="ARTWORK">
						<Texture name="$parentRaidTargetIcon" parentKey="RaidTargetIcon" file="Interface\TargetingFrame\UI-RaidTargetingIcons" setAllPoints="true"/>
					</Layer>
				</Layers>
			</Frame>
		</Frames>
		<Layers>
			<Layer level="BORDER">
				<FontString name="$parentName" parentKey="name" inherits="SystemFont_NamePlate" wordwrap="false" justifyH="CENTER"/>
			</Layer>
			<Layer level="ARTWORK">
				<Texture parentKey="selectionHighlight" file="Interface/TargetingFrame/UI-TargetingFrame-BarFill" alpha="0.25" alphaMode="ADD"/>
			</Layer>
			<Layer level="OVERLAY">
				<Texture parentKey="aggroHighlight" file="Interface/TargetingFrame/UI-TargetingFrame-BarFill" alpha="0" alphaMode="ADD">
					<Color r="1" g="1" b="0"/>
				</Texture>
			</Layer>
		</Layers>
		<Scripts>
			<OnLoad>
				self.disableMouse = true
				self.ignoreCUFNameRequirement = true
				self.isNamePlate = true

				self.name:ClearAllPoints()
				self.name:SetPoint("BOTTOM", self.healthBar, "TOP", 0, 4)
				self.selectionHighlight:ClearAllPoints()
				self.selectionHighlight:SetPoint("TOPLEFT", self.healthBar.barTexture)
				self.selectionHighlight:SetPoint("BOTTOMRIGHT", self.healthBar.barTexture)
				self.aggroHighlight:ClearAllPoints()
				self.aggroHighlight:SetPoint("TOPLEFT", self.healthBar)
				self.aggroHighlight:SetPoint("BOTTOMRIGHT", self.healthBar)

				self.healthBar.barTexture:SetDrawLayer("BORDER")

				if self.name.SetIgnoreParentScale then
					self.name:SetIgnoreParentScale(true)
				end
				if self.selectionHighlight.SetIgnoreParentAlpha then
					self.selectionHighlight:SetIgnoreParentAlpha(true)
				end
				if self.castBar.BorderShield.SetIgnoreParentAlpha then
					self.castBar.BorderShield:SetIgnoreParentAlpha(true)
				end
				if self.castBar.Icon.SetIgnoreParentAlpha then
					self.castBar.Icon:SetIgnoreParentAlpha(true)
				end

				CompactUnitFrame_OnLoad(self);
				self:RegisterForClicks("LeftButtonDown", "RightButtonUp");
			</OnLoad>
		</Scripts>
	</Button>

	<Button name="NamePlateUnitFrameTemplate" inherits="BaseNamePlateUnitFrameTemplate" virtual="true"/>
	<Button name="ForbiddenNamePlateUnitFrameTemplate" inherits="BaseNamePlateUnitFrameTemplate" virtual="true"/>

	<GameTooltip name="NamePlateTooltip" frameStrata="TOOLTIP" hidden="true" parent="UIParent" inherits="GameTooltipTemplate">
		<Scripts>
			<OnUpdate>
				self.updateTooltipTimer = (self.updateTooltipTimer or TOOLTIP_UPDATE_TIME) - elapsed;
				if self.updateTooltipTimer > 0 then
					return;
				end
				self.updateTooltipTimer = TOOLTIP_UPDATE_TIME;
				local owner = self:GetOwner();
				if owner and owner.UpdateTooltip then
					owner:UpdateTooltip();
				end
			</OnUpdate>
		</Scripts>
	</GameTooltip>
</Ui>
